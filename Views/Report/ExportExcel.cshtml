@{
    ViewData["Title"] = "Export Data Center";
}

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-8">
            <div class="mb-5">
                <i class="bi bi-cloud-arrow-down display-1 text-primary opacity-25"></i>
                <h2 class="fw-bold mt-3">Data Export Center</h2>
                <p class="text-muted">Generate and download comprehensive spreadsheets of your business data.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 p-4 hover-lift border-top border-primary border-4">
                        <i class="bi bi-box-seam fs-1 text-primary mb-3"></i>
                        <h5 class="fw-bold">Inventory</h5>
                        <p class="small text-muted">Stock levels, categories, and pricing.</p>
                        <a asp-action="DownloadInventory" class="btn btn-primary rounded-pill mt-auto">
                            <i class="bi bi-download me-1"></i> Excel
                        </a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 p-4 hover-lift border-top border-info border-4">
                        <i class="bi bi-receipt fs-1 text-info mb-3"></i>
                        <h5 class="fw-bold">Sales Ledger</h5>
                        <p class="small text-muted">Customer details and total revenue.</p>
                        <a asp-action="DownloadSales" class="btn btn-info text-white rounded-pill mt-auto">
                            <i class="bi bi-download me-1"></i> Excel
                        </a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 p-4 hover-lift border-top border-success border-4">
                        <i class="bi bi-cart-check fs-1 text-success mb-3"></i>
                        <h5 class="fw-bold">Purchases</h5>
                        <p class="small text-muted">Supplier history and procurement costs.</p>
                        <a asp-action="DownloadPurchases" class="btn btn-success rounded-pill mt-auto">
                            <i class="bi bi-download me-1"></i> Excel
                        </a>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <a asp-action="Index" class="btn btn-link text-muted"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
            </div>
        </div>
    </div>
</div>