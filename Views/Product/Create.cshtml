@model SmartInventorySystem.Models.Product

@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "Create Product" : "Edit Product";
}
<style>
    /* Styling for inputs to remove the "boxy" look */
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
    }

    .placeholder-light::placeholder {
        color: rgba(255, 255, 255, 0.5) !important;
    }

    /* Hover effect for the main button */
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2) !important;
        }

    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none small text-muted mb-2 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> Back to Inventory
        </a>
        <h2 class="fw-bold text-dark">@(isNew ? "Add New Product" : $"Edit: {Model.Name}")</h2>
    </div>

    <form asp-action="@(isNew ? "Create" : "Edit")" class="row g-4">
        <input type="hidden" asp-for="Id" />

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">General Details</h5>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="e.g. Wireless Mechanical Keyboard" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="SKU" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-qr-code"></i></span>
                                <input asp-for="SKU" class="form-control border-start-0 ps-0 shadow-none bg-light border-0" placeholder="PRD-001" />
                            </div>
                            <span asp-validation-for="SKU" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label fw-semibold"></label>
                            <input asp-for="Category" class="form-control bg-light border-0 shadow-none" placeholder="Peripherals" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Pricing & Logistics</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="SupplierId" class="form-label fw-semibold">Supplier</label>
                            <select asp-for="SupplierId" class="form-select bg-light border-0 shadow-none" asp-items="@(new SelectList(ViewBag.Suppliers, "Id", "Name"))">
                                <option value="">-- Choose Supplier --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WarehouseId" class="form-label fw-semibold">Warehouse Location</label>
                            <select asp-for="WarehouseId" class="form-select bg-light border-0 shadow-none" asp-items="@(new SelectList(ViewBag.Warehouses, "Id", "Name"))">
                                <option value="">-- Choose Warehouse --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Price" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">$</span>
                                <input asp-for="Price" class="form-control border-start-0 ps-0 shadow-none bg-light border-0" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4 bg-primary text-white overflow-hidden">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-graph-up-arrow me-2"></i>Stock Levels</h5>

                    <div class="mb-4">
                        <label asp-for="Quantity" class="form-label small text-uppercase fw-bold opacity-75"></label>
                        <input asp-for="Quantity" class="form-control form-control-lg bg-white bg-opacity-10 border-0 text-white placeholder-light" type="number" />
                    </div>

                    <div class="mb-2">
                        <label asp-for="MinStockLevel" class="form-label small text-uppercase fw-bold opacity-75"></label>
                        <input asp-for="MinStockLevel" class="form-control bg-white bg-opacity-10 border-0 text-white placeholder-light" type="number" />
                        <div class="form-text text-white-50 small">System will alert you when stock falls below this.</div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold rounded-3 shadow-sm hover-lift">
                        <i class="bi bi-save2 me-2"></i>@(isNew ? "Create Product" : "Save Changes")
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-lg py-3 fw-semibold border rounded-3">
                        Discard
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const qtyInput = document.querySelector('[name="Quantity"]');
        const minInput = document.querySelector('[name="MinStockLevel"]');
        const stockCard = document.querySelector('.bg-primary');

        function updateStockAlert() {
            const qty = parseInt(qtyInput.value) || 0;
            const min = parseInt(minInput.value) || 0;

            if (qty <= min && qty !== 0) {
                stockCard.classList.replace('bg-primary', 'bg-warning');
                stockCard.classList.add('text-dark');
                stockCard.classList.remove('text-white');
            } else {
                stockCard.classList.replace('bg-warning', 'bg-primary');
                stockCard.classList.add('text-white');
                stockCard.classList.remove('text-dark');
            }
        }

        qtyInput.addEventListener('input', updateStockAlert);
        minInput.addEventListener('input', updateStockAlert);
    </script>
}