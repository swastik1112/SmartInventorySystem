@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<SmartInventorySystem.Models.Product>

@{
    ViewData["Title"] = "Inventory Management";
    var totalItems = Model.TotalItemCount;
}
<style>
    /* Product List Specific Styles */
.fs-xs { font-size: 0.7rem; letter-spacing: 0.05rem; }

.product-thumb {
    width: 40px;
    height: 40px;
    font-size: 1.2rem;
}

.qr-preview {
    width: 35px;
    cursor: pointer;
    transition: transform 0.2s ease;
}

.qr-preview:hover {
    transform: scale(1.1);
}

/* Pagination Style Overrides */
.pagination .page-item .page-link {
    border: none;
    margin: 0 3px;
    color: #6c757d;
    border-radius: 8px !important;
}

.pagination .page-item.active .page-link {
    background-color: #0d6efd;
    color: white;
}

/* Hover Lift Effect */
.hover-lift {
    transition: transform 0.2s ease;
}
.hover-lift:hover {
    transform: translateY(-2px);
}
</style>
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-box-seam-fill me-2 text-primary"></i>Product Inventory
            </h2>
            <p class="text-muted mb-0">Manage your stock, SKUs, and track inventory health.</p>
        </div>

        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-plus-lg me-1"></i> Add New Product
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-md-5">
                    <div class="input-group input-group-merge border rounded-3">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control bg-light border-0 shadow-none" 
                               placeholder="Search by name, SKU, or category..." value="@ViewBag.CurrentFilter" />
                    </div>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-dark rounded-3 px-4">Filter</button>
                </div>
                <div class="col-md-auto">
                    <a asp-action="Index" class="btn btn-light rounded-3 px-3 border text-muted">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 px-4 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="fw-bold mb-0">All Items <span class="badge bg-light text-primary border ms-2">@totalItems</span></h6>
            <div class="dropdown">
                <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-file-earmark-excel me-2"></i>Export Excel</a></li>
                    <li><a class="dropdown-item" href="#"><i class="bi bi-printer me-2"></i>Print Labels</a></li>
                </ul>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase fs-xs fw-bold text-muted">Product Identity</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted">SKU / Code</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted" style="min-width: 150px;">Stock Status</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-center">QR</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <img src="/img/empty-box.svg" alt="Empty" style="width: 80px;" class="mb-3 opacity-50">
                                <h5 class="text-muted">No products found in the database</h5>
                                <a asp-action="Create" class="btn btn-sm btn-primary">Add your first product</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var product in Model)
                        {
                            var stockPercent = product.MinStockLevel > 0 ? (double)product.Quantity / (product.MinStockLevel * 2) * 100 : 100;
                            stockPercent = stockPercent > 100 ? 100 : stockPercent;
                            
                            var statusColor = product.Quantity <= 0 ? "danger" : 
                                              product.Quantity < product.MinStockLevel ? "warning" : "success";

                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="product-thumb me-3 rounded-3 border d-flex align-items-center justify-content-center bg-light">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@product.Name</div>
                                            <small class="text-muted">Category: Electronics</small> @* Example static text *@
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border fw-normal py-1">@product.SKU</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <small class="fw-bold text-@statusColor">@product.Quantity Units</small>
                                        <small class="text-muted">Min: @product.MinStockLevel</small>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-@statusColor" style="width: @stockPercent%"></div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrWhiteSpace(product.QRCodeBase64))
                                    {
                                        <img src="data:image/png;base64,@product.QRCodeBase64"
                                             class="qr-preview shadow-sm rounded border"
                                             data-bs-toggle="popover" 
                                             data-bs-trigger="hover"
                                             data-bs-content="<img src='data:image/png;base64,@product.QRCodeBase64' width='150' />"
                                             data-bs-html="true" />
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle shadow-sm border" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3">
                                            <li><a class="dropdown-item" asp-action="Details" asp-route-id="@product.Id"><i class="bi bi-eye me-2 text-primary"></i>View Details</a></li>
                                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                            {
                                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@product.Id"><i class="bi bi-pencil me-2 text-warning"></i>Quick Edit</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@product.Id"><i class="bi bi-trash me-2"></i>Remove Item</a></li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white border-top py-3">
            <div class="d-md-flex justify-content-between align-items-center">
                <small class="text-muted mb-3 mb-md-0">
                    Showing <strong>@Model.FirstItemOnPage</strong>-<strong>@Model.LastItemOnPage</strong> of <strong>@totalItems</strong> items
                </small>
                <nav>
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = ViewBag.CurrentFilter }),
                        new PagedListRenderOptions {
                            LiElementClasses = new[] { "page-item" },
                            PageClasses = new[] { "page-link", "shadow-none" },
                            UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0", "rounded-pill" },
                            ContainerDivClasses = new[] { "pagination-container" }
                        })
                </nav>
            </div>
        </div>
    </div>
</div>