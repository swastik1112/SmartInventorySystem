@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Revenue Trend Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: @Json.Serialize(ViewBag.ChartLabels ?? new string[0]),
                datasets: [{
                    label: 'Daily Revenue',
                    data: @Json.Serialize(ViewBag.ChartData ?? new decimal[0]),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#0d6efd',
                    pointBorderColor: '#fff',
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top' },
                    tooltip: { mode: 'index', intersect: false }
                },
                scales: {
                    y: { beginAtZero: true, title: { display: true, text: 'Revenue' } },
                    x: { title: { display: true, text: 'Date' } }
                }
            }
        });

        // Low Stock Bar Chart (example – pass real data from controller)
        const lowStockCtx = document.getElementById('lowStockChart').getContext('2d');
        new Chart(lowStockCtx, {
            type: 'bar',
            data: {
                labels: @Json.Serialize(ViewBag.LowStockLabels ?? new string[] { "No data" }),
                datasets: [{
                    label: 'Current Stock',
                    data: @Json.Serialize(ViewBag.LowStockQuantities ?? new int[] { 0 }),
                    backgroundColor: '#dc3545',
                    borderColor: '#b02a37',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: 'y', // horizontal bars for better readability
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw} units` } }
                },
                scales: {
                    x: { beginAtZero: true, title: { display: true, text: 'Quantity' } }
                }
            }
        });
    </script>
} *@