@{
    ViewData["Title"] = "Business Dashboard";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Control Center</h2>
            <p class="text-muted mb-0">Live overview of your inventory and financial health.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-light text-dark border p-2 px-3 rounded-pill shadow-sm">
                <i class="bi bi-calendar3 me-2 text-primary"></i> @DateTime.Now.ToString("dd MMM yyyy")
            </span>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100 border-start border-primary border-5">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-primary-subtle text-primary rounded-3 p-3 me-3">
                        <i class="bi bi-currency-dollar fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Monthly Revenue</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.MonthlyRevenue.ToString("C0")</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100 border-start border-info border-5">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-info-subtle text-info rounded-3 p-3 me-3">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Total Catalog</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.TotalProducts Items</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            @{
                var lowStockColor = ViewBag.LowStockItems > 0 ? "warning" : "success";
            }
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100 border-start border-@lowStockColor border-5">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-@lowStockColor-subtle text-@lowStockColor rounded-3 p-3 me-3">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Low Stock Alerts</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.LowStockItems</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100 border-start border-dark border-5">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-light text-dark rounded-3 p-3 me-3 border">
                        <i class="bi bi-cart-check fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Today's Sales</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.TodaySalesCount</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0">30-Day Revenue Trend</h5>
                </div>
                <div class="card-body">
                    <canvas id="salesChart" style="max-height: 350px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0">Stock vs Safety Level</h5>
                </div>
                <div class="card-body">
                    <canvas id="stockBarChart" style="max-height: 350px;"></canvas>
                    <div class="mt-3 p-3 bg-light rounded-3 small">
                        <i class="bi bi-info-circle me-1"></i> Showing top items needing restock.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-subtle {
        background-color: #cfe2ff !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .icon-shape {
        width: 54px;
        height: 54px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // 1. Line Chart: Revenue
    const ctxSales = document.getElementById('salesChart').getContext('2d');
    const salesGradient = ctxSales.createLinearGradient(0, 0, 0, 400);
    salesGradient.addColorStop(0, 'rgba(13, 110, 253, 0.2)');
    salesGradient.addColorStop(1, 'rgba(13, 110, 253, 0)');

    new Chart(ctxSales, {
        type: 'line',
        data: {
            labels: @Json.Serialize(ViewBag.ChartLabels),
            datasets: [{
                label: 'Daily Revenue',
                data: @Json.Serialize(ViewBag.ChartData),
                borderColor: '#0d6efd',
                backgroundColor: salesGradient,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#0d6efd',
                pointBorderWidth: 2
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { display: false } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Bar Chart: Low Stock Products
    new Chart(document.getElementById('stockBarChart'), {
        type: 'bar',
        data: {
            labels: @Json.Serialize(ViewBag.LowStockProductNames),
            datasets: [
                {
                    label: 'Current Qty',
                    data: @Json.Serialize(ViewBag.LowStockQuantities),
                    backgroundColor: '#ffc107',
                    borderRadius: 5
                },
                {
                    label: 'Min Level',
                    data: @Json.Serialize(ViewBag.LowStockMinLevels),
                    backgroundColor: '#e9ecef',
                    borderRadius: 5
                }
            ]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            plugins: { legend: { position: 'bottom' } },
            scales: { x: { display: false }, y: { grid: { display: false } } }
        }
    });
</script>