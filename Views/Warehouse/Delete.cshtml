@model Warehouse

@{
    ViewData["Title"] = "Confirm Warehouse Deletion";
}

<div class="container py-5 animate__animated animate__headShake">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger py-4 text-center text-white">
                    <i class="bi bi-building-dash display-4 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-0">Decommission Warehouse</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <p class="text-muted mb-1">You are removing this facility from the system:</p>
                        <h4 class="fw-bold text-dark">@Model.Name</h4>
                    </div>

                    <div class="alert alert-danger border-0 rounded-4 p-3 d-flex align-items-center mb-4">
                        <i class="bi bi-exclamation-octagon-fill fs-3 me-3"></i>
                        <div class="small">
                            <strong>Critical Warning:</strong> Deleting this warehouse will disconnect it from all current inventory records. Ensure all stock has been <strong>transferred</strong> before proceeding.
                        </div>
                    </div>

                    <div class="bg-light rounded-4 p-4 mb-4 border">
                        <div class="row g-3">
                            <div class="col-4 text-muted small fw-bold text-uppercase">Location</div>
                            <div class="col-8 small text-dark fw-semibold">@Model.Location</div>

                            <div class="col-4 text-muted small fw-bold text-uppercase">Capacity</div>
                            <div class="col-8 small text-dark">@Model.Capacity <span class="text-muted">Total Units</span></div>

                            <div class="col-4 text-muted small fw-bold text-uppercase">Database ID</div>
                            <div class="col-8 small font-monospace text-muted">#WH-@Model.Id.ToString("D4")</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold rounded-3 shadow-sm hover-lift">
                                <i class="bi bi-trash3 me-2"></i>Permanently Delete Facility
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg py-3 fw-semibold border rounded-3 text-muted">
                                <i class="bi bi-arrow-left me-2"></i>Cancel and Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <p class="text-center text-muted mt-4 small">
                <i class="bi bi-info-circle me-1"></i>
                Need to move stock first? <a asp-controller="Product" asp-action="Index" class="text-decoration-none">View Inventory List</a>
            </p>
        </div>
    </div>
</div>

<style>
    /* Industrial/Safety Style UI */
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .hover-lift {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(220, 53, 69, 0.2) !important;
        }

    .font-monospace {
        font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    }
</style>