@model Warehouse

@{
    ViewData["Title"] = "Edit Warehouse";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Warehouses</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark">
                <i class="bi bi-building-gear me-2 text-primary"></i>Configuring Warehouse
            </h2>
        </div>
        <div class="text-end d-none d-md-block">
            <span class="badge bg-light text-dark border p-2">
                <i class="bi bi-hash me-1"></i> ID: @Model.Id
            </span>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="card-title mb-0 fw-bold">Facility Specifications</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" id="warehouseForm">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-semibold">Warehouse Name <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="e.g. Central Distribution Hub" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Location" class="form-label fw-semibold">Physical Location <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-geo-alt text-muted"></i></span>
                                    <input asp-for="Location" class="form-control bg-light border-0 shadow-none" placeholder="Enter full address or zone" />
                                </div>
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-semibold">Storage Capacity</label>
                                <div class="input-group">
                                    <input asp-for="Capacity" class="form-control bg-light border-0 shadow-none text-end" type="number" min="0" />
                                    <span class="input-group-text bg-light border-0 fw-bold text-muted">Units</span>
                                </div>
                                <div class="form-text mt-2">Maximum unit volume for this facility.</div>
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-link text-muted fw-semibold text-decoration-none px-0">
                                <i class="bi bi-arrow-left me-1"></i> Discard Changes
                            </a>
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold rounded-3 shadow hover-lift">
                                <i class="bi bi-check2-circle me-1"></i> Update Facility
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 bg-primary text-white shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Quick Help</h5>
                    <p class="small opacity-75">
                        Editing the <strong>Capacity</strong> will affect stock percentage calculations system-wide. Ensure the value reflects current usable space.
                    </p>
                    <hr class="opacity-25">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-building fs-1 opacity-25 me-3"></i>
                        <span class="small">Currently viewing settings for: <br><strong>@Model.Name</strong></span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 text-center">
                    <p class="text-muted small mb-0">Need to remove this warehouse?</p>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger border-0 mt-2 fw-bold">
                        <i class="bi bi-trash me-1"></i> Delete Location
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light {
        background-color: #f1f4f8 !important;
    }

    .hover-lift {
        transition: transform 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
        }

    .form-control:focus {
        background-color: #fff !important;
        border: 1px solid #0d6efd !important;
    }

    .breadcrumb-item a {
        color: #6c757d;
    }

    .breadcrumb-item.active {
        color: #0d6efd;
        font-weight: 600;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}