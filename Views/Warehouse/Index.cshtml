@model IEnumerable<Warehouse>

@{
    ViewData["Title"] = "Warehouse Management";
}
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-building me-2 text-primary"></i>Warehouses
            </h2>
            <p class="text-muted mb-0">Manage physical storage locations and inventory capacities.</p>
        </div>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-plus-lg me-1"></i> Add Warehouse
            </a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 hover-lift">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="icon-shape bg-primary-subtle text-primary rounded-3">
                                <i class="bi bi-geo-alt-fill fs-4"></i>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye me-2"></i>View Details</a></li>
                                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                    }
                                </ul>
                            </div>
                        </div>

                        <h4 class="fw-bold text-dark mb-1">@item.Name</h4>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-map me-1"></i> @item.Location
                        </p>

                        <div class="mt-4">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-bold">Storage Capacity</small>
                                <small class="text-muted">@item.Capacity units</small>
                            </div>
                            <div class="progress" style="height: 8px;">
                                @* Assuming you'll eventually calculate actual usage *@
                                <div class="progress-bar bg-primary" role="progressbar" style="width: 65%;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 py-3 px-4">
                        <a asp-action="Details" asp-route-id="@item.Id" class="text-primary text-decoration-none small fw-bold">
                            View Inventory <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>