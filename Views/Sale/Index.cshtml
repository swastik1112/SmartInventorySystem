@model IEnumerable<Sale>

@{
    ViewData["Title"] = "Sales Ledger";
    // Quick calculations for the Top Stats
    var totalRevenue = Model.Sum(s => s.Quantity * s.PricePerUnit);
    var totalItemsSold = Model.Sum(s => s.Quantity);
    var transactionCount = Model.Count();
}
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-receipt-cutoff text-primary me-2"></i>Sales Ledger
            </h2>
            <p class="text-muted mb-0">Track customer invoices and revenue flow.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary rounded-pill px-3 shadow-sm">
                <i class="bi bi-download me-1"></i> Export
            </button>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-lightning-charge-fill me-1"></i> New Sale
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-primary-subtle text-primary rounded-3 p-3 me-3">
                        <i class="bi bi-currency-dollar fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Total Revenue</h6>
                        <h4 class="fw-bold mb-0">@totalRevenue.ToString("C")</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-info-subtle text-info rounded-3 p-3 me-3">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Items Sold</h6>
                        <h4 class="fw-bold mb-0">@totalItemsSold</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-warning-subtle text-warning rounded-3 p-3 me-3">
                        <i class="bi bi-hash fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small uppercase fw-bold">Transactions</h6>
                        <h4 class="fw-bold mb-0">@transactionCount</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted fs-xs fw-bold text-uppercase">Invoice Date</th>
                        <th class="py-3 text-muted fs-xs fw-bold text-uppercase">Customer</th>
                        <th class="py-3 text-muted fs-xs fw-bold text-uppercase">Product Item</th>
                        <th class="py-3 text-muted fs-xs fw-bold text-uppercase">Qty</th>
                        <th class="py-3 text-muted fs-xs fw-bold text-uppercase">Unit Price</th>
                        <th class="py-3 text-muted fs-xs fw-bold text-uppercase">Total Revenue</th>
                        <th class="py-3 text-muted fs-xs fw-bold text-uppercase text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
                                No sales recorded yet. Click "New Sale" to get started.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark">@item.SaleDate.ToString("dd MMM yyyy")</span>
                                    <small class="text-muted">@item.SaleDate.ToShortTimeString()</small>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-xs bg-secondary-subtle text-secondary rounded-circle me-2 d-flex align-items-center justify-content-center fw-bold" style="width: 30px; height: 30px; font-size: 12px;">
                                        @item.CustomerName.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-semibold">@item.CustomerName</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">@item.Product?.Name</span>
                            </td>
                            <td>
                                <span class="fw-bold">@item.Quantity</span>
                            </td>
                            <td class="text-muted">@item.PricePerUnit.ToString("C")</td>
                            <td>
                                <span class="text-primary fw-bold">@((item.Quantity * item.PricePerUnit).ToString("C"))</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm border" title="Print Invoice">
                                        <i class="bi bi-printer text-primary"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-white btn-sm border" title="Void Transaction">
                                        <i class="bi bi-trash text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .fs-xs {
        font-size: 0.7rem;
    }

    .hover-lift {
        transition: transform 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
        }

    .btn-white {
        background: white;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    .bg-primary-subtle {
        background-color: #cfe2ff !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }
</style>