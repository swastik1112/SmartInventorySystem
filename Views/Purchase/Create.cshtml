@model Purchase

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-success py-4 text-center text-white">
                    <h3 class="fw-bold mb-0"><i class="bi bi-cart-plus me-2"></i>New Purchase Order</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Supplier</label>
                                <select asp-for="SupplierId" class="form-select bg-light border-0" asp-items="ViewBag.Suppliers"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Date</label>
                                <input asp-for="PurchaseDate" type="date" class="form-control bg-light border-0" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Product</label>
                                <select asp-for="ProductId" class="form-select bg-light border-0" asp-items="ViewBag.Products"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Quantity</label>
                                <input asp-for="Quantity" id="qty" class="form-control bg-light border-0" placeholder="0" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Cost Per Unit</label>
                                <input asp-for="PricePerUnit" id="price" class="form-control bg-light border-0" placeholder="0.00" />
                            </div>
                        </div>

                        <div class="mt-4 p-3 rounded-3 bg-success-subtle border border-success text-center">
                            <span class="text-uppercase small fw-bold text-success">Estimated Total Cost</span>
                            <h2 class="fw-bold text-success mb-0">$<span id="total">0.00</span></h2>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg py-3 fw-bold rounded-3">Confirm & Stock Inventory</button>
                            <a asp-action="Index" class="btn btn-link text-muted">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const qty = document.getElementById('qty');
    const price = document.getElementById('price');
    const total = document.getElementById('total');

    [qty, price].forEach(el => el.addEventListener('input', () => {
        const res = (parseFloat(qty.value) || 0) * (parseFloat(price.value) || 0);
        total.innerText = res.toLocaleString(undefined, {minimumFractionDigits: 2});
    }));
</script>