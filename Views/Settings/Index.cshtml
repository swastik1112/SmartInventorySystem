@{
    ViewData["Title"] = "System Settings";
}

<div class="container py-5">
    <div class="row g-5">
        <div class="col-md-4 col-lg-3">
            <h4 class="fw-bold mb-4">Settings</h4>
            <div class="nav flex-column nav-pills shadow-sm rounded-4 bg-white p-2" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                <button class="nav-link active py-3 text-start" id="v-pills-general-tab" data-bs-toggle="pill" data-bs-target="#v-pills-general" type="button">
                    <i class="bi bi-sliders2 me-2"></i> General
                </button>
                <button class="nav-link py-3 text-start" id="v-pills-security-tab" data-bs-toggle="pill" data-bs-target="#v-pills-security" type="button">
                    <i class="bi bi-shield-lock me-2"></i> Password & Security
                </button>
                <button class="nav-link py-3 text-start" id="v-pills-notifications-tab" data-bs-toggle="pill" data-bs-target="#v-pills-notifications" type="button">
                    <i class="bi bi-bell me-2"></i> Notifications
                </button>
            </div>
        </div>

        <div class="col-md-8 col-lg-9">
            <div class="tab-content" id="v-pills-tabContent">

                <div class="tab-pane fade show active" id="v-pills-general" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4">Display Preferences</h5>
                        <form asp-action="UpdatePreference" method="post">
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">Interface Theme</label>
                                <div class="d-flex gap-3">
                                    <div class="flex-fill">
                                        <input type="radio" class="btn-check" name="theme" id="lightMode" checked>
                                        <label class="btn btn-outline-primary w-100 py-3 rounded-3" for="lightMode">
                                            <i class="bi bi-sun fs-4 d-block mb-1"></i> Light
                                        </label>
                                    </div>
                                    <div class="flex-fill">
                                        <input type="radio" class="btn-check" name="theme" id="darkMode">
                                        <label class="btn btn-outline-primary w-100 py-3 rounded-3" for="darkMode">
                                            <i class="bi bi-moon-stars fs-4 d-block mb-1"></i> Dark
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">System Language</label>
                                <select class="form-select border-0 bg-light rounded-3">
                                    <option value="en">English (US)</option>
                                    <option value="es">Español</option>
                                    <option value="fr">Français</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Save Changes</button>
                        </form>
                    </div>
                </div>

                <div class="tab-pane fade" id="v-pills-security" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4">Update Password</h5>
                        <form>
                            <div class="mb-3">
                                <label class="form-label small">Current Password</label>
                                <input type="password" class="form-control bg-light border-0" placeholder="••••••••">
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small">New Password</label>
                                    <input type="password" class="form-control bg-light border-0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small">Confirm New Password</label>
                                    <input type="password" class="form-control bg-light border-0">
                                </div>
                            </div>
                            <button type="button" class="btn btn-dark rounded-pill px-4 mt-2">Change Password</button>
                        </form>
                    </div>
                </div>

                <div class="tab-pane fade" id="v-pills-notifications" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4">Notification Channels</h5>
                        <div class="list-group list-group-flush">
                            <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h6 class="mb-0 fw-bold">Email Alerts</h6>
                                    <small class="text-muted">Receive low stock and purchase reports via email.</small>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" checked>
                                </div>
                            </div>
                            <div class="list-group-item border-0 px-0 d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h6 class="mb-0 fw-bold">Browser Notifications</h6>
                                    <small class="text-muted">Real-time alerts while using the inventory app.</small>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: #495057;
        font-weight: 500;
        transition: all 0.2s;
    }

        .nav-pills .nav-link.active {
            background-color: #f8f9fa;
            color: #0d6efd;
            border-left: 4px solid #0d6efd;
            border-radius: 0;
        }

    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }

    body {
        background-color: #f4f7f6;
    }
</style>