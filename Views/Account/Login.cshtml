@using SmartInventorySystem.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "Log in";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 mt-5">
                <div class="card-body p-5">
                    <h3 class="text-center mb-4 fw-bold">Smart Inventory System</h3>
                    <p class="text-center text-muted mb-4">Sign in to continue</p>

                    @if (ViewData.ModelState.IsValid == false)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" autofocus />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" type="password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                            </div>

                            <a asp-action="ForgotPassword" asp-controller="Account" class="text-decoration-none small">
                                Forgot password?
                            </a>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Sign In
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <small class="text-muted">
                            Don't have an account?
                            <a asp-action="Register" asp-controller="Account" class="text-primary text-decoration-none">
                                Register here
                            </a>
                        </small>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4 text-muted small">
                © @DateTime.Now.Year Smart Inventory System
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}