@model IEnumerable<AuditLog>

@{
    ViewData["Title"] = "System Audit Logs";
    var pageSize = (int)(ViewBag.PageSize ?? 25);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
    var currentPage = (int)(ViewBag.Page ?? 1);
}
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-shield-shaded text-primary me-2"></i>Security Audit Trail
            </h2>
            <p class="text-muted mb-0">Complete history of system changes and user operations.</p>
        </div>
        <div>
            <form asp-action="ClearAll" method="post" onsubmit="return confirm('WARNING: This will permanently delete ALL audit records. Continue?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger rounded-pill px-4 shadow-sm">
                    <i class="bi bi-trash3 me-2"></i>Purge All Logs
                </button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Keyword Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control border-0 bg-light" placeholder="User, details, or ID..." value="@ViewBag.Search" />
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted text-uppercase">Module</label>
                    <select name="entity" class="form-select border-0 bg-light">
                        <option value="">All Entities</option>
                        <option value="Product" selected="@(ViewBag.Entity == "Product")">Product</option>
                        <option value="Purchase" selected="@(ViewBag.Entity == "Purchase")">Purchase</option>
                        <option value="Sale" selected="@(ViewBag.Entity == "Sale")">Sale</option>
                        <option value="Stock" selected="@(ViewBag.Entity == "Stock")">Stock</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted text-uppercase">Action Type</label>
                    <select name="actionType" class="form-select border-0 bg-light">
                        <option value="">All Actions</option>
                        <option value="Create" selected="@(ViewBag.ActionType == "Create")">➕ Create</option>
                        <option value="Update" selected="@(ViewBag.ActionType == "Update")">📝 Update</option>
                        <option value="Delete" selected="@(ViewBag.ActionType == "Delete")">🗑️ Delete</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Timeframe</label>
                    <div class="input-group">
                        <input type="date" name="dateFrom" class="form-control border-0 bg-light" value="@ViewBag.DateFrom" />
                        <input type="date" name="dateTo" class="form-control border-0 bg-light" value="@ViewBag.DateTo" />
                    </div>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary rounded-3">
                        <i class="bi bi-funnel-fill me-2"></i>Apply
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small text-uppercase fw-bold">Timestamp</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">User Account</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Action</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Target Module</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Record ID</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Modification Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="bi bi-clipboard-x display-4 text-muted opacity-25"></i>
                                <p class="text-muted mt-3">No audit records found matching your criteria.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        var badgeClass = log.Action switch
                        {
                            "Create" => "bg-success text-success",
                            "Update" => "bg-warning text-warning",
                            "Delete" => "bg-danger text-danger",
                            _ => "bg-primary text-primary"
                        };

                        <tr>
                            <td class="ps-4">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark">@log.Timestamp.ToString("dd MMM yyyy")</span>
                                    <small class="text-muted">@log.Timestamp.ToString("HH:mm:ss")</small>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-xs bg-dark text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width:30px; height:30px; font-size: 12px;">
                                        @(log.User?.UserName?.Substring(0, 1).ToUpper() ?? "?")
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">@(log.User?.UserName ?? "System Process")</div>
                                        <small class="text-muted" style="font-size: 0.75rem;">ID: @log.UserId?.Split('-')[0]...</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill border @badgeClass bg-opacity-10 px-3 py-2" style="font-size: 10px; letter-spacing: 0.5px;">
                                    @log.Action.ToUpper()
                                </span>
                            </td>
                            <td>
                                <span class="text-dark fw-semibold">@log.Entity</span>
                            </td>
                            <td>
                                <code class="bg-light px-2 py-1 rounded text-primary fw-bold">#@log.EntityId</code>
                            </td>
                            <td>
                                <div class="text-muted small text-wrap" style="max-width: 350px;">
                                    @log.Details
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white border-top py-3">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Showing <strong>@Model.Count()</strong> of <strong>@totalCount</strong> results</span>

                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link shadow-none" asp-action="Index" asp-route-page="@(currentPage - 1)"
                               asp-route-search="@ViewBag.Search" asp-route-entity="@ViewBag.Entity" asp-route-actionType="@ViewBag.ActionType">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        <li class="page-item disabled">
                            <span class="page-link bg-light text-dark fw-bold">Page @currentPage of @totalPages</span>
                        </li>

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link shadow-none" asp-action="Index" asp-route-page="@(currentPage + 1)"
                               asp-route-search="@ViewBag.Search" asp-route-entity="@ViewBag.Entity" asp-route-actionType="@ViewBag.ActionType">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-xs {
        flex-shrink: 0;
    }

    .table thead th {
        border-top: none;
    }

    .page-link {
        border: none;
        padding: 0.5rem 1rem;
    }

    .badge.bg-opacity-10 {
        background-color: rgba(var(--bs-primary-rgb), 0.1);
    }

    .bg-success.bg-opacity-10 {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .bg-warning.bg-opacity-10 {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    .bg-danger.bg-opacity-10 {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }
</style>