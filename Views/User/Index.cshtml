@using SmartInventorySystem.ViewModels
@model IEnumerable<UserViewModel>

<h2>Users Management</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New User</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Full Name</th>
            <th>Roles</th>
            <th>Confirmed</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>
                <td>@item.FullName</td>
                <td>@string.Join(", ", item.Roles)</td>
                <td>@(item.EmailConfirmed ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a> |
                    <a asp-action="ResetPassword" asp-route-id="@item.Id">Reset Password</a>
                </td>
            </tr>
        }
    </tbody>
</table>