@using SmartInventorySystem.ViewModels
@model EditUserViewModel

<h2>Edit User</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="FullName"></label>
        <input asp-for="FullName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Roles</label>
        <select multiple asp-for="SelectedRoles" class="form-control">
            @foreach (var role in Model.AvailableRoles)
            {
                <option value="@role" selected="@(Model.SelectedRoles?.Contains(role) ?? false)">@role</option>
            }
        </select>
    </div>

    <div class="form-check">
        <input asp-for="EmailConfirmed" class="form-check-input" type="checkbox" />
        <label asp-for="EmailConfirmed" class="form-check-label">Email Confirmed</label>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>

<!-- Link to reset password separately -->
<p class="mt-4">
    <a asp-action="ResetPassword" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
        Reset Password
    </a>
</p>