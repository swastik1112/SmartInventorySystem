@using SmartInventorySystem.ViewModels
@model UserViewModel

@{
    ViewData["Title"] = "Delete User";
}
<style>
    /* Animated Pulse for the warning icon */
    .animate__infinite {
        animation-iteration-count: infinite;
    }

    /* Scannable small text */
    .fs-xs {
        font-size: 0.7rem;
        letter-spacing: 0.05rem;
        text-transform: uppercase;
    }

    /* Subdued background for the summary box */
    .bg-secondary-subtle {
        background-color: rgba(108, 117, 125, 0.1) !important;
    }

    /* Hover lift effect for the main action */
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3) !important;
        }
</style>

<div class="container py-5 animate__animated animate__zoomIn">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger py-4 text-center text-white">
                    <i class="bi bi-exclamation-triangle-fill display-4 animate__animated animate__pulse animate__infinite"></i>
                    <h3 class="fw-bold mt-2">Critical Action</h3>
                </div>

                <div class="card-body p-4 p-md-5 text-center">
                    <h4 class="fw-bold text-dark mb-3">Delete User Account?</h4>
                    <p class="text-muted mb-4">
                        You are about to permanently remove <span class="text-danger fw-bold">@Model.Email</span>.
                        This action cannot be undone.
                    </p>

                    <div class="bg-light rounded-3 p-3 mb-4 text-start border-start border-danger border-4">
                        <div class="mb-2">
                            <small class="text-muted d-block uppercase fs-xs fw-bold">Full Name</small>
                            <span class="fw-semibold">@Model.FullName</span>
                        </div>
                        <div class="mb-2">
                            <small class="text-muted d-block uppercase fs-xs fw-bold">Assigned Roles</small>
                            <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                @string.Join(", ", Model.Roles)
                            </span>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold shadow-sm hover-lift" id="confirmDeleteBtn">
                                Yes, Delete Account
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg py-3 fw-semibold">
                                No, Keep User
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <p class="text-center mt-4 text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                Deleted users will lose all access to the Smart Inventory System immediately.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Loading state to prevent double clicks on a destructive action
        document.querySelector('form').onsubmit = function() {
            const btn = document.getElementById('confirmDeleteBtn');
            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> Deleting...`;
        };
    </script>
}