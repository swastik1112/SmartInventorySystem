@using SmartInventorySystem.ViewModels
@model RoleEditViewModel

@{
    ViewData["Title"] = "Edit Role";
}
<style>
    /* Custom Sidebar Styling */
    .bg-primary-subtle {
        background-color: rgba(13, 110, 253, 0.1) !important;
    }

    .avatar-xs {
        width: 30px;
        height: 30px;
        flex-shrink: 0;
    }

    .truncate {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Custom Scrollbar for the User List */
    .user-scroll-area::-webkit-scrollbar {
        width: 4px;
    }

    .user-scroll-area::-webkit-scrollbar-track {
        background: transparent;
    }

    .user-scroll-area::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
    }

    /* Subtle Hover lift for the Save button */
    .hover-lift {
        transition: transform 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
        }
</style>

<div class="container py-5 animate__animated animate__fadeIn">
    <nav aria-label="breadcrumb" class="mb-4">
        <a asp-action="Index" class="text-decoration-none small text-muted">
            <i class="bi bi-arrow-left me-1"></i> Back to Roles
        </a>
    </nav>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary-subtle p-3 rounded-3 me-3">
                            <i class="bi bi-pencil-square text-primary fs-4"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold mb-0">Edit Role</h2>
                            <p class="text-muted mb-0">Modify security group settings</p>
                        </div>
                    </div>

                    <form asp-action="Edit" id="editRoleForm">
                        <input type="hidden" asp-for="Id" />

                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control bg-light border-0" placeholder="Role Name" />
                            <label asp-for="Name">Role Name</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-bold rounded-3 hover-lift shadow-sm" id="saveBtn">
                                Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 py-2 fw-semibold rounded-3 border">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white h-100">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 d-flex justify-content-between align-items-center">
                        <span>Active Members</span>
                        <span class="badge bg-primary rounded-pill fw-normal">@Model.UsersInRole.Count</span>
                    </h5>

                    @if (Model.UsersInRole.Any())
                    {
                        <p class="text-white-50 small mb-4">The following users will be impacted by changes to this role's permissions.</p>

                        <div class="user-scroll-area pe-2" style="max-height: 300px; overflow-y: auto;">
                            @foreach (var user in Model.UsersInRole)
                            {
                                <div class="d-flex align-items-center p-2 mb-2 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-10">
                                    <div class="avatar-xs bg-primary rounded-circle me-3 d-flex align-items-center justify-content-center small fw-bold">
                                        @user.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="small truncate">@user</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-people text-white-50 display-4 d-block mb-3"></i>
                            <p class="text-white-50 mb-0">No users currently assigned.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('editRoleForm').onsubmit = function() {
            if($(this).valid()){
                const btn = document.getElementById('saveBtn');
                btn.disabled = true;
                btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> Saving...`;
            }
        };
    </script>
}