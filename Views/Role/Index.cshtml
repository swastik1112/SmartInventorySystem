@using SmartInventorySystem.ViewModels
@model IEnumerable<RoleViewModel>

@{
    ViewData["Title"] = "Role Permissions";
}

<style>
    /* Custom Icon Box */
    .role-icon-box {
        width: 45px;
        height: 45px;
        background-color: #f0f4ff;
        transition: all 0.3s ease;
    }

    tr:hover .role-icon-box {
        background-color: #0d6efd;
    }

        tr:hover .role-icon-box i {
            color: white !important;
        }

    /* Modern Progress Bar */
    .progress {
        background-color: #e9ecef;
        overflow: visible;
    }

    /* Button Group Styling */
    .btn-white {
        background-color: #fff;
        border: 1px solid #edf2f9;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    /* Subtle Badge for Roles */
    .bg-primary-subtle {
        background-color: rgba(13, 110, 253, 0.1) !important;
    }

    /* Typography */
    .fs-xs {
        font-size: 0.72rem;
        letter-spacing: 0.08rem;
    }

    .tracking-tight {
        letter-spacing: -0.02rem;
    }
</style>
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="fw-bold tracking-tight text-dark mb-1">Role Permissions</h2>
            <p class="text-muted small">Define access levels and manage security groups</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-shield-plus me-2"></i>Create New Role
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div class="alert @(TempData["Success"] != null ? "alert-success" : "alert-danger") border-0 shadow-sm alert-dismissible fade show rounded-4 mb-4 animate__animated animate__headShake" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi @(TempData["Success"] != null ? "bi-check-circle-fill" : "bi-exclamation-octagon-fill") me-3 fs-4"></i>
                <div>
                    @(TempData["Success"] ?? TempData["Error"])
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase fs-xs fw-bold text-muted" style="width: 40%;">Role Identity</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted">User Coverage</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-end pe-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="role-icon-box me-3 rounded-3 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-shield-lock-fill text-primary"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-dark">@role.Name</h6>
                                        <small class="text-muted">Access Level: @(role.Name.ToLower() == "superadmin" ? "Full Access" : "Restricted")</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px; max-width: 100px;">
                                        <div class="progress-bar bg-primary rounded-pill" style="width: @(role.UserCount > 0 ? "75%" : "0%")"></div>
                                    </div>
                                    <span class="badge rounded-pill bg-primary-subtle text-primary px-3">
                                        @role.UserCount Users
                                    </span>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-white btn-sm px-3 border-end" title="Edit Permissions">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-white btn-sm px-3" title="Delete Role">
                                        <i class="bi bi-trash3 text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>