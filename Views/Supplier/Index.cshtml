@model IEnumerable<Supplier>

@{
    ViewData["Title"] = "Supplier Directory";
}
<div style="min-height: 5vh;"></div>
<div class="container-fluid py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-truck me-2 text-primary"></i>Suppliers
            </h2>
            <p class="text-muted mb-0">Manage your vendor relationships and contact points.</p>
        </div>

        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-person-plus-fill me-1"></i> Add New Supplier
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase fs-xs fw-bold text-muted">Company</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Contact Person</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Contact Info</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Location</th>
                        <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold">
                                        @item.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-bold text-dark">@item.Name</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-semibold">@item.ContactPerson</span>
                                    <small class="text-muted">Primary Representative</small>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <a href="mailto:@item.Email" class="text-decoration-none small text-primary">
                                        <i class="bi bi-envelope me-1"></i> @item.Email
                                    </a>
                                    <a href="tel:@item.Phone" class="text-decoration-none small text-muted">
                                        <i class="bi bi-telephone me-1"></i> @item.Phone
                                    </a>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span class="text-muted small text-truncate" style="max-width: 150px;"
                                          data-bs-toggle="tooltip" title="@item.Address">
                                        <i class="bi bi-geo-alt me-1"></i> @(string.IsNullOrEmpty(item.Address) ? "No address" : item.Address)
                                    </span>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm border" title="Details">
                                        <i class="bi bi-info-circle"></i>
                                    </a>
                                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white btn-sm border text-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-white btn-sm border text-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .avatar-sm {
        width: 38px;
        height: 38px;
        min-width: 38px;
    }

    .btn-white {
        background: white;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }
</style>