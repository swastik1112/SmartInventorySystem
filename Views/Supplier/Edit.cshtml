@model Supplier

@{
    ViewData["Title"] = "Edit Supplier";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none small text-muted">
            <i class="bi bi-chevron-left"></i> Back to Supplier Directory
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-4 px-5 text-white">
                    <div class="d-flex align-items-center">
                        <div class="avatar-md bg-white text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold fs-4" style="width: 50px; height: 50px;">
                            @Model.Name.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <h3 class="fw-bold mb-0">Edit Supplier Profile</h3>
                            <p class="text-white-50 mb-0 small">Updating information for <strong>@Model.Name</strong></p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Edit" class="needs-validation">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <h6 class="text-primary text-uppercase fw-bold fs-xs border-bottom pb-2 mb-3">Company Identity</h6>
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-semibold">Company Name <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="e.g. Global Logistics Corp" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ContactPerson" class="form-label fw-semibold">Primary Representative</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="ContactPerson" class="form-control bg-light border-0 shadow-none" placeholder="Full Name" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold">Business Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control bg-light border-0 shadow-none" type="email" placeholder="contact@company.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-telephone text-muted"></i></span>
                                    <input asp-for="Phone" class="form-control bg-light border-0 shadow-none" placeholder="+1 (555) 000-0000" />
                                </div>
                            </div>

                            <div class="col-12">
                                <h6 class="text-primary text-uppercase fw-bold fs-xs border-bottom pb-2 mb-3 mt-3">Logistics & Address</h6>
                                <div class="mb-3">
                                    <label asp-for="Address" class="form-label fw-semibold">Physical Address</label>
                                    <textarea asp-for="Address" class="form-control bg-light border-0 shadow-none" rows="3" placeholder="Street, City, State, ZIP"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-link text-muted fw-semibold text-decoration-none">
                                <i class="bi bi-x-lg me-1"></i> Discard Changes
                            </a>
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold rounded-3 shadow-sm hover-lift">
                                <i class="bi bi-check2-circle me-1"></i> Update Supplier Profile
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-xs {
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }

    .bg-light {
        background-color: #f8f9fa !important;
    }

    .hover-lift {
        transition: transform 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
        }

    .form-control:focus {
        background-color: #fff !important;
        border: 1px solid #0d6efd !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}