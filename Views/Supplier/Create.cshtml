@model Supplier

@{
    var isNew = Model == null || Model.Id == 0;
    ViewData["Title"] = isNew ? "Register Supplier" : "Edit Supplier";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle mb-3 mx-auto" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-briefcase fs-3"></i>
                        </div>
                        <h3 class="fw-bold">@(isNew ? "New Supplier" : "Update Records")</h3>
                        <p class="text-muted small">Ensure contact details are accurate for purchasing orders.</p>
                    </div>

                    <form asp-action="@(isNew ? "Create" : "Edit")" class="row g-3">
                        <input type="hidden" asp-for="Id" />

                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-bold">Company Name</label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="e.g. Acme Logistics Inc." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="ContactPerson" class="form-label fw-bold">Contact Representative</label>
                            <input asp-for="ContactPerson" class="form-control bg-light border-0" placeholder="Full Name" />
                            <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control bg-light border-0" type="email" placeholder="name@company.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-bold">Phone Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Phone" class="form-control bg-light border-0" placeholder="+1 (555) 000-0000" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold">Business Location</label>
                            <div class="input-group">
                                @* The icon prefix helps users identify the field type immediately *@
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-geo-alt text-primary"></i>
                                </span>

                                <input asp-for="Address" class="form-control bg-light border-0 shadow-none"
                                       placeholder="Enter full business address..." />
                            </div>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold rounded-3 shadow-sm hover-lift">
                                    <i class="bi bi-check2-circle me-2"></i>@(isNew ? "Register Supplier" : "Save Changes")
                                </button>
                                <a asp-action="Index" class="btn btn-link text-muted">Discard Changes</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>