@model Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <nav aria-label="breadcrumb" class="mb-4">
        <a asp-action="Index" class="text-decoration-none small text-muted">
            <i class="bi bi-arrow-left me-1"></i> Back to Suppliers
        </a>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark py-5 text-center text-white">
                    <div class="avatar-lg bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-lg fw-bold fs-2" style="width: 80px; height: 80px;">
                        @Model.Name.Substring(0, 1).ToUpper()
                    </div>
                    <h2 class="fw-bold mb-1">@Model.Name</h2>
                    <p class="opacity-75 mb-0">Partner Vendor Since @DateTime.Now.Year</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h5 class="fw-bold border-bottom pb-2 mb-4">Contact Information</h5>

                            <div class="d-flex mb-4">
                                <div class="icon-box me-3 text-primary"><i class="bi bi-person-badge fs-4"></i></div>
                                <div>
                                    <small class="text-muted d-block text-uppercase fw-bold fs-xs">Primary Contact</small>
                                    <span class="h6 fw-bold">@Model.ContactPerson</span>
                                </div>
                            </div>

                            <div class="d-flex mb-4">
                                <div class="icon-box me-3 text-primary"><i class="bi bi-envelope fs-4"></i></div>
                                <div>
                                    <small class="text-muted d-block text-uppercase fw-bold fs-xs">Email Address</small>
                                    <a href="mailto:@Model.Email" class="h6 text-primary text-decoration-none">@Model.Email</a>
                                </div>
                            </div>

                            <div class="d-flex mb-4">
                                <div class="icon-box me-3 text-primary"><i class="bi bi-telephone fs-4"></i></div>
                                <div>
                                    <small class="text-muted d-block text-uppercase fw-bold fs-xs">Phone Number</small>
                                    <a href="tel:@Model.Phone" class="h6 text-dark text-decoration-none">@Model.Phone</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold border-bottom pb-2 mb-4">Business Location</h5>
                            <div class="p-4 rounded-4 bg-light border border-dashed text-center">
                                <i class="bi bi-geo-alt fs-1 text-muted mb-3 d-block"></i>
                                <p class="h6 mb-3 px-3">@Model.Address</p>
                                <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(Model.Address)"
                                   target="_blank" class="btn btn-sm btn-dark rounded-pill px-4">
                                    <i class="bi bi-map me-2"></i>View on Maps
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top text-center">
                        <div class="btn-group shadow-sm">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 py-2 fw-bold">
                                <i class="bi bi-pencil me-2"></i>Update Supplier
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4 py-2 fw-bold">
                                <i class="bi bi-trash me-2"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>