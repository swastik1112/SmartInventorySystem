<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Inventory</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @RenderSection("Styles", required: false)
    <style>
        :root {
            --sidebar-width: 280px;
            --sidebar-collapsed-width: 85px;
            --topbar-height: 70px;
            --primary-accent: #4361ee;
            --sidebar-bg: #111827; /* Deep Navy/Grey */
            --body-bg: #f9fafb;
            --transition-speed: 0.3s;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: #1f2937;
            overflow-x: hidden;
        }

        /* --- Sidebar Design --- */
        #sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            box-shadow: 10px 0 15px -3px rgba(0, 0, 0, 0.07);
        }

            #sidebar.collapsed {
                width: var(--sidebar-collapsed-width);
            }

        .sidebar-brand {
            height: var(--topbar-height);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .sidebar-heading {
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: #6b7280;
            padding: 1.5rem 1.5rem 0.5rem;
        }

        #sidebar .nav-link {
            color: #9ca3af;
            padding: 0.8rem 1.5rem;
            margin: 0.2rem 0.75rem;
            border-radius: 10px;
            display: flex;
            align-items: center;
            transition: all 0.2s;
            white-space: nowrap;
        }

            #sidebar .nav-link:hover {
                color: #fff;
                background: rgba(255, 255, 255, 0.08);
            }

            #sidebar .nav-link.active {
                color: #fff;
                background: var(--primary-accent);
                box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
            }

            #sidebar .nav-link i {
                font-size: 1.25rem;
                min-width: 35px;
            }

        #sidebar.collapsed .nav-link span,
        #sidebar.collapsed .sidebar-heading,
        #sidebar.collapsed .brand-text {
            display: none;
        }

        /* --- Topbar Design --- */
        #topbar {
            position: fixed;
            top: 0;
            right: 0;
            left: var(--sidebar-width);
            height: var(--topbar-height);
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e5e7eb;
            z-index: 1000;
            transition: left var(--transition-speed);
        }

            #topbar.collapsed {
                left: var(--sidebar-collapsed-width);
            }

        /* --- Main Content --- */
        #main-content {
            margin-left: var(--sidebar-width);
            padding-top: var(--topbar-height);
            transition: margin-left var(--transition-speed);
            min-height: 100vh;
        }

            #main-content.collapsed {
                margin-left: var(--sidebar-collapsed-width);
            }

        .user-avatar {
            width: 38px;
            height: 38px;
            background: #e5e7eb;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: var(--primary-accent);
        }

        @@media (max-width: 992px) {
            #sidebar

        {
            left: calc(var(--sidebar-width) * -1);
        }

        #sidebar.mobile-show {
            left: 0;
        }

        #topbar, #main-content {
            left: 0 !important;
            margin-left: 0 !important;
        }

        }
    </style>
</head>
<body>

    <nav id="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-stack text-primary fs-3 me-2"></i>
            <span class="text-white fw-bold fs-5 brand-text">SmartStock</span>
        </div>

        <div class="flex-grow-1 overflow-auto">
            <div class="sidebar-heading">Main Menu</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-grid-1x2"></i> <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> <span>Products</span>
                    </a>
                </li>

                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                {
                    <div class="sidebar-heading">Inventory Ops</div>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Purchase" ? "active" : "")" asp-controller="Purchase" asp-action="Index">
                            <i class="bi bi-cart-plus"></i> <span>Purchases</span>
                        </a>
                    </li>
                }

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Sale" ? "active" : "")" asp-controller="Sale" asp-action="Index">
                        <i class="bi bi-receipt"></i> <span>Sales</span>
                    </a>
                </li>

                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Supplier" ? "active" : "")" asp-controller="Supplier" asp-action="Index">
                            <i class="bi bi-truck"></i> <span>Suppliers</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Warehouse" ? "active" : "")" asp-controller="Warehouse" asp-action="Index">
                            <i class="bi bi-building"></i> <span>Warehouses</span>
                        </a>
                    </li>

                    <div class="sidebar-heading">Reports & Tools</div>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Report" asp-action="Index">
                            <i class="bi bi-bar-chart-line"></i> <span>Reports</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Report" asp-action="ExportExcel">
                            <i class="bi bi-file-earmark-spreadsheet"></i> <span>Export Data</span>
                        </a>
                    </li>
                }

                @if (User.IsInRole("SuperAdmin"))
                {
                    <div class="sidebar-heading">Administration</div>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
                            <i class="bi bi-people"></i> <span>User Management</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Role" asp-action="Index">
                            <i class="bi bi-shield-lock"></i> <span>Role Permissions</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Audit" asp-action="Index">
                            <i class="bi bi-clock-history"></i> <span>Audit Logs</span>
                        </a>
                    </li>
                }
            </ul>
        </div>

        <div class="p-3 border-top border-white border-opacity-10 text-center">
            <small class="text-muted">© @DateTime.Now.Year Smart Inventory</small>
        </div>
    </nav>

    <header id="topbar" class="d-flex align-items-center px-4">
        <button class="btn btn-light border shadow-sm rounded-circle me-3" id="sidebarToggle">
            <i class="bi bi-list fs-5"></i>
        </button>

        <h5 class="mb-0 fw-bold d-none d-md-block text-dark">System Overview</h5>

        <div class="ms-auto d-flex align-items-center">
            <div class="dropdown">
                <div class="d-flex align-items-center gap-3" role="button" data-bs-toggle="dropdown">
                    <div class="text-end d-none d-sm-block">
                        <div class="fw-bold small text-dark">@User.Identity?.Name</div>
                        <div class="text-muted extra-small" style="font-size: 11px;">System User</div>
                    </div>
                    <div class="user-avatar shadow-sm">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 p-2">
                    <li><a class="dropdown-item rounded-2" href="#"><i class="bi bi-person me-2"></i> Profile</a></li>
                    <li><a class="dropdown-item rounded-2" href="#"><i class="bi bi-gear me-2"></i> Settings</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item rounded-2 text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <main id="main-content" class="p-4">
        <div class="container-fluid animate-fade-in">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');
            const topbar = document.getElementById('topbar');
            const toggleBtn = document.getElementById('sidebarToggle');

            toggleBtn.addEventListener('click', function () {
                const isMobile = window.innerWidth <= 992;
                if (isMobile) {
                    sidebar.classList.toggle('mobile-show');
                } else {
                    sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('collapsed');
                    topbar.classList.toggle('collapsed');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>